{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true, /* Tự tạo file .d.ts để các app khác hiểu type */
    "outDir": "./dist"
  },
  "include": ["src"]
}